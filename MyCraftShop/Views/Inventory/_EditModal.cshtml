@model MyCraftShop.Models.InventoryItem

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" id="editItemForm">
    <div class="modal-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CostPerItem" class="form-label"></label>
            <input asp-for="CostPerItem" class="form-control" type="number" step="0.01" min="0.01" />
            <span asp-validation-for="CostPerItem" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SalesPrice" class="form-label"></label>
            <input asp-for="SalesPrice" class="form-control" type="number" step="0.01" min="0.01" />
            <span asp-validation-for="SalesPrice" class="text-danger"></span>
            <div class="form-text">Optional. Leave blank if not applicable.</div>
        </div>

        <div class="mb-3">
            <label asp-for="Quantity" class="form-label"></label>
            <input asp-for="Quantity" class="form-control" type="number" step="0.01" min="0" />
            <span asp-validation-for="Quantity" class="text-danger"></span>
            <div class="form-text">Decimals and percentages are supported (e.g., 0.5 for half).</div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
    </div>
</form>
